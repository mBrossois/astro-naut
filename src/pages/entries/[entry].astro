---
import type { Entry, Media } from '@cms/payload-types';
import Layout from '../../layouts/Layout.astro';
import InfoBlock from '../../components/InfoBlock.astro';
import { lexicalToHTML } from '../../utils/lexicalToHtml';
import { sanitizeHTML } from '../../utils/sanitizeHtml';
import { CMS_API } from 'astro:env/server';

export async function getStaticPaths() {
  const response = await fetch(`${CMS_API}/api/entries`, {
    method: 'GET',
    headers: {
      'Content-Type': 'application/json',
      'x-access-token': '12345',
    },
  });

  const data = await response.json();
  const entries: Entry[] = data.docs ?? [];

  return entries.map(entry => ({
    params: { entry: entry.slug },
    props: { entryData: entry },
  }));
}

const { entryData } = Astro.props;

const learningsHtml = lexicalToHTML(entryData?.learnings);
const nextStepsHtml = lexicalToHTML(entryData?.nextSteps);
const learningsHtmlSanitized = sanitizeHTML(learningsHtml);
const nextStepsHtmlSanitized = sanitizeHTML(nextStepsHtml);

const date = new Date(entryData?.releasedAt);
console.log(date)
---

<Layout>
    <div class="container p-8 flex flex-col gap-4">
        <ul class="list-none! text-xs text-purple-200">
            {entryData?.tags.map((tag) => (
                <li key={tag.id}>{tag.tag}</li>
            ))}
        </ul>
        <div class="flex flex-col gap-1">
            <span class="text-purple-50 text-xs">{date.toLocaleString('en-US', { month: 'short' })} {date.toLocaleString('en-US', { day: 'numeric' })}, {date.toLocaleString('en-US', { year: 'numeric' })}</span>
            <h1 class="text-4xl font-bold text-purple-300">{entryData?.title}</h1>
        </div>
        <p class="description text-purple-50">{entryData?.description}</p>
        <img src={`http://localhost:3000${(entryData?.thumbnail as Media)?.url}`} alt={entryData?.title} class="h-48 w-full object-cover rounded-lg" />
        <div class="text-white flex flex-col gap-4">
            <InfoBlock>
                <span class="contents" slot="title">Learnings</span>
                <div slot="description"><div class="rich-text" set:html={learningsHtmlSanitized} /></div>
            </InfoBlock>
            <InfoBlock>
                <span class="contents" slot="title">Next Steps</span>
                <div slot="description"><div class="rich-text" set:html={nextStepsHtmlSanitized} /></div>
            </InfoBlock>
        </div>
    </div>
</Layout>