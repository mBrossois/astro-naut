---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro-naut</title>
	</head>
	<body class="bg-gray-950">
		<header class="bg-black border-b border-gray-800 text-purple-300 p-4">
			<nav class="container flex gap-4 items-center">
				<a href="/" class="text-2xl font-bold">Astro-naut</a>
				<Nav />
			</nav>
		</header>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
